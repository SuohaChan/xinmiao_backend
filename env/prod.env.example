# ==========================
# Xinmiao - Prod Environment
# ==========================
# 说明：
# - 这只是示例文件，部署机上请复制为 env/prod.env（不要提交到仓库）
# - 生产环境强烈建议用更强的密码与随机密钥
#
# Docker 后端（Dockerfile 只打包本机/CI 已编译的 jar，见仓库根 Dockerfile）：
#   mvn -f pom.xml -DskipTests package
#   docker compose --env-file env/prod.env build backend
#   docker compose --env-file env/prod.env --profile backend up -d
# 改代码后：重新 package，再 build backend（或 up --build）。

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=9090

JWT_SECRET=PLEASE_SET_A_STRONG_RANDOM_SECRET
SPRING_AI_OPENAI_API_KEY=PLEASE_SET_REAL_KEY

# 生产前端域名（按需改）
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com

# ---------- MySQL (prod) ----------
MYSQL_PORT=3307
MYSQL_ROOT_PASSWORD=PLEASE_SET_STRONG_PASSWORD
MYSQL_DATABASE=xinmiao
MYSQL_USER=xinmiao
MYSQL_PASSWORD=PLEASE_SET_STRONG_PASSWORD

# 如果后端与 mysql 同 compose 网络：用 mysql:3306；如果是外部 DB：改成真实地址
DB_URL=jdbc:mysql://mysql:3306/xinmiao?serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf-8&zeroDateTimeBehavior=convertToNull&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=xinmiao
DB_PASSWORD=PLEASE_SET_STRONG_PASSWORD

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- RabbitMQ ----------
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=PLEASE_SET_STRONG_PASSWORD

# ---------- Chroma ----------
CHROMA_PORT=8000
CHROMA_HOST=http://chroma

# ---------- Zipkin ----------
ZIPKIN_PORT=9411
MANAGEMENT_ZIPKIN_TRACING_ENDPOINT=http://zipkin:9411/api/v2/spans

