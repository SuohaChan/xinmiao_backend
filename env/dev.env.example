# =========================
# Xinmiao - Dev Environment
# =========================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=9090

# 强烈建议本地也替换成自己的随机值
JWT_SECRET=PLEASE_CHANGE_ME_TO_A_LONG_RANDOM_SECRET
SPRING_AI_OPENAI_API_KEY=PLEASE_CHANGE_ME

# 本地前端地址
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:5500,http://localhost:80

# ---------- MySQL (dev) ----------
# 如果你本机 3306 已被占用（比如装了 MySQL/宝塔），这里改成 3307/13306 都可以
MYSQL_PORT=3307
MYSQL_ROOT_PASSWORD=PLEASE_CHANGE_ME
MYSQL_DATABASE=xinmiao
MYSQL_USER=xinmiao
MYSQL_PASSWORD=PLEASE_CHANGE_ME

# 后端跑在本机时：用 localhost:${MYSQL_PORT}
DB_URL=jdbc:mysql://localhost:3307/xinmiao?serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf-8&zeroDateTimeBehavior=convertToNull&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=xinmiao
DB_PASSWORD=PLEASE_CHANGE_ME

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_HOST=127.0.0.1

# ---------- RabbitMQ ----------
# 须与 broker 一致。compose 默认 admin / admin123（见 docker-compose rabbitmq 服务）。
# 若启动报 ACCESS_REFUSED：常见原因是本机另有 RabbitMQ 占用 5672（账号不同），或容器首次创建后改过密码（需删卷重建或改回密码）。
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=PLEASE_CHANGE_ME
RABBITMQ_HOST=localhost
# 仅开发：true 时启动即连接 MQ；false 时延迟连接监听（可先起后端再修 MQ 账号）
RABBIT_LISTENER_AUTO_STARTUP=true

# ---------- 离线 RAG 评测（可选）----------
# Spring 会把 RAG_EVAL_FILE 映射为 rag.eval.file。若填写，须与仓库目录一致，例如：
# RAG_EVAL_FILE=eval/cases/eval.jsonl
# RAG_EVAL_OUT=eval/reports/rag-eval-result.json
# 不要再用已废弃的 eval/eval.jsonl。

# ---------- Chroma ----------
CHROMA_PORT=8000
# 后端跑在本机：用 http://localhost；后端跑在容器：用 http://chroma
CHROMA_HOST=http://localhost

# ---------- Zipkin ----------
ZIPKIN_PORT=9411
MANAGEMENT_ZIPKIN_TRACING_ENDPOINT=http://localhost:9411/api/v2/spans

